rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role']) &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.role is string && data.role.size() <= 50;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && 
                    request.auth.uid == userId && 
                    isValidId(userId) && 
                    isValidUser(incoming());
      allow update: if isSignedIn() && 
                    request.auth.uid == userId && 
                    isValidId(userId) && 
                    isValidUser(incoming()) && 
                    incoming().role == existing().role;
    }

    match /devices/{deviceId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid && 
                    isValidId(deviceId);
      allow update, delete: if isSignedIn() && 
                    existing().userId == request.auth.uid;
    }

    match /groups/{groupId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid && 
                    isValidId(groupId);
      allow update, delete: if isSignedIn() && 
                    existing().userId == request.auth.uid;
    }

    match /forecast/{forecastId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid && 
                    isValidId(forecastId);
      allow update, delete: if isSignedIn() && 
                    existing().userId == request.auth.uid;
    }

    match /settings/{settingId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid && 
                    isValidId(settingId);
      allow update, delete: if isSignedIn() && 
                    existing().userId == request.auth.uid;
    }

    match /activity_log/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && 
                    existing().userId == request.auth.uid;
    }

    match /realtime_metrics/{metricId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid;
    }
  }
}
